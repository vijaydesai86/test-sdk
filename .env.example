# ─── Stock Data Provider ──────────────────────────────────────────────────────
# Controls which stock data API is used. Options: alphavantage | finnhub | hybrid
# Default: alphavantage
STOCK_DATA_PROVIDER=alphavantage

# Alpha Vantage API Key  (required when STOCK_DATA_PROVIDER=alphavantage or hybrid)
# Free tier: 25 requests/day — https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# Finnhub API Key  (required when STOCK_DATA_PROVIDER=finnhub or hybrid)
# Free tier: 60 requests/minute — https://finnhub.io/register
FINNHUB_API_KEY=your_finnhub_key_here
