# Alpha Vantage API Key (recommended; used automatically when configured)
# Get your free API key at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# Finnhub API Key (recommended; used automatically when configured)
# Get your free API key at: https://finnhub.io
FINNHUB_API_KEY=your_finnhub_key_here

# Financial Modeling Prep API Key (optional; used automatically when configured)
# Get your free API key at: https://financialmodelingprep.com/developer/docs
FINANCIAL_MODELING_PREP_API_KEY=your_fmp_key_here

# Twelve Data API Key (optional; used automatically when configured)
# Get your free API key at: https://twelvedata.com/pricing
TWELVE_DATA_API_KEY=your_twelve_data_key_here

# Optional fallback/specialist providers.
# These are used only for suitable data types and fallback gaps, not as a brute-force default.
EODHD_API_KEY=
MARKETAUX_API_KEY=
OPENFIGI_API_KEY=

# LLM settings (all optional)
# The app automatically uses every configured provider/model fallback it can.
# COPILOT_MODEL=openai/gpt-4.1
# COPILOT_FALLBACK_MODELS=openai/gpt-4.1-mini,google/gemini-3-flash
# GEMINI_MODEL=gemini-2.5-flash
# FILL_MODEL=openai/gpt-4.1-mini
# LLM_REQUEST_TIMEOUT_MS=30000
# LLM_FILL_REQUEST_TIMEOUT_MS=12000
# LLM_FILL_TOTAL_BUDGET_MS=20000

# Stock data provider selection is automatic. Configure any combination of keys above;
# the app tries all configured providers with Stooq as a no-key price-history fallback.

# Number of companies in comparison, sector, and deep-sector reports.
# Optimal: 10 — broad coverage without exhausting the free-tier rate limit (5 req/min AV).
# Raise to 15 for deeper analysis; lower to 5 for faster / demo runs.
# NUM_COMPANIES=10

# Deep-sector research fetches verified market data before optional ecosystem LLM enrichment.
# Default is one post-core-data pass; raise locally only if provider/model budget allows.
# DEEP_RESEARCH_DEPTH=1

# Max runtime budget for deep sector research (ms). Default keeps under Vercel 300s.
# DEEP_RESEARCH_MAX_MS=240000

# Concurrency for per-ticker data fetch (higher = faster, lower = fewer rate limits)
# DATA_FETCH_CONCURRENCY=3

# Provider-specific throttling (milliseconds between requests)
# ALPHA_VANTAGE_MIN_INTERVAL_MS=12000
# FINNHUB_MIN_INTERVAL_MS=1100
# FMP_MIN_INTERVAL_MS=12000
# TWELVE_DATA_MIN_INTERVAL_MS=8000
# STOOQ_MIN_INTERVAL_MS=1000
# EODHD_MIN_INTERVAL_MS=12000
# MARKETAUX_MIN_INTERVAL_MS=1500
# OPENFIGI_MIN_INTERVAL_MS=3000

# Cache the live GitHub Models catalog so deep research requests do not re-fetch it every turn
# GITHUB_MODELS_CACHE_TTL_MS=900000

# LLM model cooldown (ms) after rate-limit errors
# LLM_MODEL_COOLDOWN_MS=120000

# How long (ms) to pause a provider after a rate-limit/auth error
# STOCK_PROVIDER_COOLDOWN_MS=300000

# FRED API Key (optional — enables macroeconomic indicators tool)
# Get a free key at: https://fred.stlouisfed.org/docs/api/api_key.html
# Provides: GDP, CPI/inflation, Fed Funds rate, unemployment, Treasury yields, yield curve
# FRED_API_KEY=your_fred_api_key_here

# Optional official/no-key data source tuning.
# BLS_API_KEY is optional; the BLS macro tool works without it under lower public limits.
# BLS_API_KEY=
# BEA_API_KEY=
# EIA_API_KEY=
# SEC_USER_AGENT=StockResearchBot/1.0 contact@example.com
# SEC_COMPANY_FACTS_CACHE_TTL_MS=43200000
# TREASURY_RATES_CACHE_TTL_MS=43200000
# BLS_MACRO_CACHE_TTL_MS=43200000
# BEA_CACHE_TTL_MS=43200000
# EIA_CACHE_TTL_MS=43200000
