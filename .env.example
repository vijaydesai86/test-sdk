# Alpha Vantage API Key (required for alphavantage and hybrid mode)
# Get your free API key at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# Finnhub API Key (required for finnhub and hybrid mode)
# Get your free API key at: https://finnhub.io
FINNHUB_API_KEY=your_finnhub_key_here

# Financial Modeling Prep API Key (optional, enables FMP provider and multi-source fallback)
# Get your free API key at: https://financialmodelingprep.com/developer/docs
FINANCIAL_MODELING_PREP_API_KEY=your_fmp_key_here

# Twelve Data API Key (optional, enables Twelve Data provider and multi-source fallback)
# Get your free API key at: https://twelvedata.com/pricing
TWELVE_DATA_API_KEY=your_twelve_data_key_here

# LLM settings (all optional)
# The app automatically uses every configured provider/model fallback it can.
# COPILOT_MODEL=openai/gpt-4.1
# COPILOT_FALLBACK_MODELS=anthropic/claude-3.7-sonnet,openai/gpt-4.1-mini
# GEMINI_MODEL=gemini-2.5-flash
# FILL_MODEL=openai/gpt-4.1-mini

# Number of companies in comparison, sector, and deep-sector reports.
# Optimal: 10 — broad coverage without exhausting the free-tier rate limit (5 req/min AV).
# Raise to 15 for deeper analysis; lower to 5 for faster / demo runs.
# NUM_COMPANIES=10

# Number of recursive refinement passes in deep sector research (Phase 3).
# Each pass feeds the prior dependency analysis as context, deepening insights.
# Optimal: 2 — meaningfully richer analysis with only one extra LLM call.
# Raise to 3 for the most thorough research; set to 1 to disable recursion.
# DEEP_RESEARCH_DEPTH=2

# Max runtime budget for deep sector research (ms). Default keeps under Vercel 300s.
# DEEP_RESEARCH_MAX_MS=240000

# Concurrency for per-ticker data fetch (higher = faster, lower = fewer rate limits)
# DATA_FETCH_CONCURRENCY=3

# Provider-specific throttling (milliseconds between requests)
# ALPHA_VANTAGE_MIN_INTERVAL_MS=1200
# FINNHUB_MIN_INTERVAL_MS=500
# FMP_MIN_INTERVAL_MS=800
# TWELVE_DATA_MIN_INTERVAL_MS=800
# STOOQ_MIN_INTERVAL_MS=800

# LLM model cooldown (ms) after rate-limit errors
# LLM_MODEL_COOLDOWN_MS=120000

# How long (ms) to pause a provider after a rate-limit/auth error
# STOCK_PROVIDER_COOLDOWN_MS=300000

# FRED API Key (optional — enables macroeconomic indicators tool)
# Get a free key at: https://fred.stlouisfed.org/docs/api/api_key.html
# Provides: GDP, CPI/inflation, Fed Funds rate, unemployment, Treasury yields, yield curve
# FRED_API_KEY=your_fred_api_key_here
