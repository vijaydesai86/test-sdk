# Alpha Vantage API Key (required for alphavantage and hybrid mode)
# Free: 25 req/day, 5/min — covers quotes, fundamentals, financials, macro, commodities, forex
# Get your free API key at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# Finnhub API Key (required for finnhub and hybrid mode)
# Free: 60 req/min — covers quotes, news, analyst data, dividends, splits, earnings/IPO calendars
# Get your free API key at: https://finnhub.io
FINNHUB_API_KEY=your_finnhub_key_here

# FRED (Federal Reserve Economic Data) API Key
# RECOMMENDED: Unlocks get_market_indicators — VIX, yield curve, S&P 500, CPI, PCE,
# unemployment, mortgage rates, credit spreads, consumer sentiment.
# Free instant signup (no credit card): https://fred.stlouisfed.org/docs/api/api_key.html
# FRED_API_KEY=your_fred_api_key_here

# CoinGecko API Key (optional — improves crypto rate limits from ~10 to 30 req/min)
# Get free key at: https://www.coingecko.com/en/api → "Get API Key"
# COINGECKO_API_KEY=your_coingecko_demo_key_here

# Stock data provider: alphavantage | finnhub | hybrid
# STRONGLY RECOMMENDED: set to 'hybrid' if you have both API keys.
# - alphavantage: Alpha Vantage only (default if not set)
# - finnhub:      Finnhub only
# - hybrid:       Alpha Vantage as primary, Finnhub fills gaps — maximum data coverage
STOCK_DATA_PROVIDER=hybrid

# LLM provider selection (determines which AI API handles LLM calls)
# - github (default): GitHub Models API only — requires GITHUB_TOKEN
# - gemini:           Gemini API only — requires GEMINI_TOKEN
# - hybrid:           GitHub Models primary; auto-falls back to Gemini on HTTP 429 rate limit
# LLM_PROVIDER=github

# Number of companies in comparison, sector, and deep-sector reports.
# Optimal: 10 — broad coverage without exhausting the free-tier rate limit (5 req/min AV).
# Raise to 15 for deeper analysis; lower to 5 for faster / demo runs.
# NUM_COMPANIES=10

# Number of recursive refinement passes in deep sector research (Phase 3).
# Each pass feeds the prior dependency analysis as context, deepening insights.
# Optimal: 2 — meaningfully richer analysis with only one extra LLM call.
# Raise to 3 for the most thorough research; set to 1 to disable recursion.
# DEEP_RESEARCH_DEPTH=2
