# GitHub Token (REQUIRED - uses your existing Copilot subscription!)
# Create a Personal Access Token at: https://github.com/settings/tokens
# Scopes needed: Read access to your repos (if using private repos)
# Note: This uses your existing GitHub Copilot subscription - NO additional cost!
GITHUB_TOKEN=ghp_your_token_here

# Alpha Vantage API Key (required for alphavantage and hybrid mode)
# Get your free API key at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# Finnhub API Key (required for finnhub and hybrid mode)
# Get your free API key at: https://finnhub.io
FINNHUB_API_KEY=your_finnhub_key_here

# Stock data provider: alphavantage | finnhub | hybrid
# - alphavantage: Alpha Vantage only (default if not set)
# - finnhub:      Finnhub only
# - hybrid:       Alpha Vantage as primary, Finnhub fills gaps
STOCK_DATA_PROVIDER=alphavantage
