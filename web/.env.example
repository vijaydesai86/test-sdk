# Copy this file to .env.local for local development.
# Keep real values only in .env.local or Vercel environment variables.

# LLM providers: configure at least one.
# GitHub token can be GITHUB_TOKEN, GH_TOKEN, or COPILOT_GITHUB_TOKEN.
GITHUB_TOKEN=
GEMINI_TOKEN=

# Optional LLM model/fallback tuning.
# COPILOT_MODEL=openai/gpt-4.1
# COPILOT_FALLBACK_MODEL=openai/gpt-4.1
# COPILOT_FALLBACK_MODELS=openai/gpt-4.1-mini,openai/gpt-4.1
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_FALLBACK_MODELS=gemini-2.5-flash,gemini-2.5-flash-lite
# GEMINI_ENABLE_PRO_FALLBACK=false
# GEMINI_CHAT_REASONING_EFFORT=low
# GEMINI_FILL_REASONING_EFFORT=low
# FILL_MODEL=openai/gpt-4.1-mini
# FILL_FALLBACK_MODELS=openai/gpt-4.1-mini,openai/gpt-4.1
# AUTO_DOWNGRADE_GPT5=true
# LLM_REQUEST_TIMEOUT_MS=30000
# LLM_FILL_REQUEST_TIMEOUT_MS=12000
# LLM_FILL_TOTAL_BUDGET_MS=20000
# LLM_MODEL_COOLDOWN_MS=120000
# GITHUB_MODELS_CACHE_TTL_MS=900000

# Stock data providers: configure at least one keyed provider.
# The app automatically tries every configured provider; no provider selector is needed.
ALPHA_VANTAGE_API_KEY=
FINNHUB_API_KEY=
FINANCIAL_MODELING_PREP_API_KEY=
TWELVE_DATA_API_KEY=
EODHD_API_KEY=
MARKETAUX_API_KEY=
OPENFIGI_API_KEY=

# Optional data sources.
FRED_API_KEY=
BLS_API_KEY=
BEA_API_KEY=
EIA_API_KEY=
SEC_USER_AGENT=

# Supabase persistence: optional locally, expected on Vercel when configured there.
# SUPABASE_ANON_KEY is listed for Vercel parity; server routes use the service role key.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Report/watchlist/memory storage. Defaults are local files in ./reports locally and /tmp on Vercel.
# REPORTS_DIR=reports
# WATCHLISTS_FILE=reports/watchlists.json
# RESEARCH_MEMORY_FILE=reports/research-memory.json

# Research/report tuning.
# NUM_COMPANIES=10
# Research uses a broader verified role-bucketed company/ticker candidate pool before theme/data/coverage scoring.
# Broad resolver output is raw discovery only; full research reports require concrete direct/enabler role readiness.
# Default is 3x the configured company count; range is 1-5.
# RESEARCH_CANDIDATE_POOL_MULTIPLIER=3
# RESEARCH_THEME_FACET_COUNT=6
# RESEARCH_FACET_CANDIDATES=8
# RESEARCH_UNIVERSE_MIN_THEME_SCORE=70
# RESEARCH_UNIVERSE_STRONG_ADJACENT_THEME_SCORE=55
# RESEARCH_UNIVERSE_ALLOW_STRONG_ADJACENT=true
# RESEARCH_UNIVERSE_MAX_ROLE_SHARE=0.35
# Deep-sector research fetches verified market data before optional ecosystem LLM enrichment.
# Default is one post-core-data pass; range is 1-10. Raise only if provider/model budget allows.
# DEEP_RESEARCH_DEPTH=1
# DEEP_RESEARCH_MAX_MS=240000
# RESEARCH_ALLOCATION_MIN_SCORE=60
# RESEARCH_ALLOCATION_MIN_THEME_SCORE=50
# RESEARCH_ALLOCATION_MIN_DATA_CONFIDENCE=50
# DATA_FETCH_CONCURRENCY=3
# VERCEL_EXTENDED_DATA_MAX_COMPANIES=3
# VERCEL_FUNCTION_TIMEOUT_MS=300000
# VERCEL_INTERNAL_DEADLINE_BUFFER_MS=25000
# VERCEL_REPORT_RETURN_BUFFER_MS=45000
# VERCEL_REPORT_LLM_MIN_REMAINING_MS=120000
# STOCK_CACHE_TTL_MS=604800000
# SEC_COMPANY_FACTS_CACHE_TTL_MS=43200000
# TREASURY_RATES_CACHE_TTL_MS=43200000
# BLS_MACRO_CACHE_TTL_MS=43200000
# BEA_CACHE_TTL_MS=43200000
# EIA_CACHE_TTL_MS=43200000
# STOCK_PROVIDER_COOLDOWN_MS=300000
# Generated-report and saved-report Improve pass tuning.
# REPORT_IMPROVE_DEFAULT_PASSES=3
# REPORT_IMPROVE_MAX_PASSES=5
# REPORT_IMPROVE_TARGET=critical
# REPORT_IMPROVE_MIN_WAIT_MS=60000

# Provider throttle tuning.
# ALPHA_VANTAGE_MIN_INTERVAL_MS=12000
# FINNHUB_MIN_INTERVAL_MS=1100
# FMP_MIN_INTERVAL_MS=12000
# TWELVE_DATA_MIN_INTERVAL_MS=8000
# STOOQ_MIN_INTERVAL_MS=1000
# EODHD_MIN_INTERVAL_MS=12000
# MARKETAUX_MIN_INTERVAL_MS=1500
# OPENFIGI_MIN_INTERVAL_MS=3000

# Diagnostics.
# DEBUG=false
# HEALTH_CHECK_SYMBOL=AAPL
# USE_FULL_SYSTEM_PROMPT=false

# Legacy variables present in some deployments. They are ignored by current code.
# STOCK_DATA_PROVIDER=
# LLM_PROVIDER=
