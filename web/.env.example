# GitHub Token (REQUIRED - uses your existing Copilot subscription!)
# Create a Personal Access Token at: https://github.com/settings/tokens
# Scopes needed: Read access to your repos (if using private repos)
# Note: This uses your existing GitHub Copilot subscription - NO additional cost!
GITHUB_TOKEN=ghp_your_token_here

# Gemini API Token (required when LLM_PROVIDER=gemini or LLM_PROVIDER=hybrid)
# Get a free key at: https://aistudio.google.com/api-keys
# IMPORTANT: use aistudio.google.com — NOT Google Cloud Console.
# AI Studio keys include free-tier quota automatically.
# Free tier for gemini-2.5-flash: 5 RPM / 250K TPM / 20 RPD.
# NEVER commit this value; set it in Vercel environment variables only.
# GEMINI_TOKEN=your_gemini_api_key_here

# LLM provider selection (determines which AI API handles LLM calls)
# - github (default): GitHub Models API only — requires GITHUB_TOKEN
# - gemini:           Gemini API only — requires GEMINI_TOKEN
# - hybrid:           GitHub Models primary; auto-falls back to Gemini on HTTP 429 rate limit
# Mirrors the STOCK_DATA_PROVIDER pattern for data services.
# LLM_PROVIDER=github

# Alpha Vantage API Key (required for alphavantage and hybrid mode)
# Get your free API key at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# Finnhub API Key (required for finnhub and hybrid mode)
# Get your free API key at: https://finnhub.io
FINNHUB_API_KEY=your_finnhub_key_here

# Stock data provider: alphavantage | finnhub | yfinance | hybrid
# - alphavantage: Alpha Vantage only (default if not set)
# - finnhub:      Finnhub only
# - yfinance:     Python yfinance proxy only (requires YFINANCE_PROXY_URL)
# - hybrid:       Alpha Vantage → Finnhub → YFinance fallback chain
#                 (uses whichever secondary/tertiary providers are configured)
STOCK_DATA_PROVIDER=alphavantage

# YFinance Python proxy URL (required for yfinance and hybrid mode with yfinance)
# Point this at your running Python yfinance REST microservice.
# The proxy server is NOT bundled in this repo — see AGENT.md for setup details.
# YFINANCE_PROXY_URL=http://localhost:5001

# Debug mode: show data-source and data-coverage sections in reports
# When true, reports include "Data Sources" and "Data Coverage (Chart Inputs)" sections.
# These are diagnostic/debug sections only — omit or set to false in production.
# DEBUG=true
