# Copy this file to .env.local for local development.
# Keep real values only in .env.local or Vercel environment variables.

# LLM providers: configure at least one.
# GitHub token can be GITHUB_TOKEN, GH_TOKEN, or COPILOT_GITHUB_TOKEN.
GITHUB_TOKEN=
GEMINI_TOKEN=

# Optional LLM model/fallback tuning.
# COPILOT_MODEL=openai/gpt-4.1
# COPILOT_FALLBACK_MODEL=openai/gpt-4.1
# COPILOT_FALLBACK_MODELS=openai/gpt-4.1-mini,google/gemini-3-flash
# GEMINI_MODEL=gemini-2.5-flash
# FILL_MODEL=openai/gpt-4.1-mini
# AUTO_DOWNGRADE_GPT5=true
# LLM_REQUEST_TIMEOUT_MS=60000
# LLM_MODEL_COOLDOWN_MS=120000
# GITHUB_MODELS_CACHE_TTL_MS=900000

# Stock data providers: configure at least one keyed provider.
# The app automatically tries every configured provider; no provider selector is needed.
ALPHA_VANTAGE_API_KEY=
FINNHUB_API_KEY=
FINANCIAL_MODELING_PREP_API_KEY=
TWELVE_DATA_API_KEY=

# Optional data sources.
FRED_API_KEY=
COINGECKO_API_KEY=

# Supabase persistence: optional locally, expected on Vercel when configured there.
# SUPABASE_ANON_KEY is listed for Vercel parity; server routes use the service role key.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Report/watchlist/memory storage. Defaults are local files in ./reports locally and /tmp on Vercel.
# REPORTS_DIR=reports
# WATCHLISTS_FILE=reports/watchlists.json
# RESEARCH_MEMORY_FILE=reports/research-memory.json

# Research/report tuning.
# NUM_COMPANIES=10
# DEEP_RESEARCH_DEPTH=2
# DEEP_RESEARCH_MAX_MS=240000
# DATA_FETCH_CONCURRENCY=3
# VERCEL_EXTENDED_DATA_MAX_COMPANIES=3
# STOCK_CACHE_TTL_MS=604800000
# STOCK_PROVIDER_COOLDOWN_MS=300000

# Provider throttle tuning.
# ALPHA_VANTAGE_MIN_INTERVAL_MS=12000
# FINNHUB_MIN_INTERVAL_MS=1100
# FMP_MIN_INTERVAL_MS=12000
# TWELVE_DATA_MIN_INTERVAL_MS=8000
# STOOQ_MIN_INTERVAL_MS=1000

# Diagnostics.
# DEBUG=false
# HEALTH_CHECK_SYMBOL=AAPL
# USE_FULL_SYSTEM_PROMPT=false

# Legacy variables present in some deployments. They are ignored by current code.
# STOCK_DATA_PROVIDER=
# LLM_PROVIDER=
# YFINANCE_PROXY_URL=
